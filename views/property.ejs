<!DOCTYPE html>
<html>
<head>
  <title><%= pg.title %></title>
  <link rel="stylesheet" href="/public/style.css">
  <meta name="viewport" content="width=device-width,initial-scale=1">
</head>
<body>
  <%- include("partials/nav") %>

  <div class="container">
    <div class="card">
      <h2><%= pg.title %></h2>
      <div class="small"><%= pg.address || "" %> <%= pg.city ? (" | " + pg.city) : "" %></div>
      <div style="margin:8px 0;"><b>₹<%= pg.price %></b> / month</div>

      <div class="row" style="margin-top:10px;">
        <% if (pg.whatsapp_number) { %>
          <a class="btn" target="_blank" href="https://wa.me/<%= pg.whatsapp_number.replace(/[^0-9]/g,'') %>?text=Hi%20I%20want%20to%20book%20<%= encodeURIComponent(pg.title) %>">WhatsApp</a>
        <% } %>
        <% if (pg.location_url) { %>
          <a class="btn secondary" target="_blank" href="<%= pg.location_url %>">Location</a>
        <% } %>
        <% if (currentUser) { %>
          <a class="btn secondary" href="/book/<%= pg.id %>">Book Now</a>
        <% } else { %>
          <a class="btn secondary" href="/login">Login to Book</a>
        <% } %>
      </div>
    </div>

    <div class="card">
      <h3>Images</h3>
      <div class="grid">
        <% (images || []).forEach(img => { %>
          <img class="img" src="/uploads/<%= img.filename %>">
        <% }) %>
      </div>
      <% if (!images || images.length === 0) { %>
        <div class="small">No images uploaded.</div>
      <% } %>
    </div>

    <div class="card">
      <h3>Details</h3>
      <p><%= pg.description || "No description." %></p>

      <h4>Facilities</h4>
      <p><%= pg.facilities || "Not mentioned." %></p>

      <h4>Owner</h4>
      <div class="small"><%= pg.owner_name || "" %> <%= pg.owner_phone ? (" | " + pg.owner_phone) : "" %></div>
    </div>
  </div>
</body>
</html>