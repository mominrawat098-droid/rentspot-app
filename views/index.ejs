<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="stylesheet" href="/style.css">
  <title>RentSpot</title>
</head>
<body>
  <%- include("partials_nav") %>

  <div class="container" style="padding:18px 0 28px;">
    <h2>Available PGs</h2>

    <% if (!pgs || pgs.length === 0) { %>
      <p>No PG added yet.</p>
    <% } else { %>
      <div class="grid">
        <% pgs.forEach(pg => { %>
          <div class="card">
            <h3><%= pg.title %></h3>
            <div class="muted"><%= pg.city %></div>
            <div style="margin-top:8px;"><b>₹<%= pg.price %>/month</b></div>
            <div class="muted" style="margin-top:6px;">
              ⭐ <%= pg.avg_rating ? pg.avg_rating : "0" %> (<%= pg.review_count || 0 %> reviews)
            </div>
            <div style="margin-top:12px;">
              <a class="btn" href="/pg/<%= pg.id %>">View</a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>