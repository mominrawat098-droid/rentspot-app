<!DOCTYPE html>
<html>
<head>
  <title>RentSpot</title>
  <link rel="stylesheet" href="/public/style.css">
  <meta name="viewport" content="width=device-width,initial-scale=1">
</head>
<body>
  <%- include("partials/nav") %>

  <div class="container">
    <div class="card">
      <h2>Available PGs</h2>
      <p class="small">Browse and book PGs. Admin can add new PGs from dashboard.</p>
    </div>

    <% if (!pgs || pgs.length === 0) { %>
      <div class="card">No PG added yet.</div>
    <% } else { %>
      <div class="grid">
        <% pgs.forEach(pg => { 
          const imgs = imageMap.get(pg.id) || [];
          const cover = imgs[0] ? ("/uploads/" + imgs[0]) : "";
        %>
          <div class="card">
            <% if (cover) { %>
              <img class="img" src="<%= cover %>">
            <% } else { %>
              <div class="img"></div>
            <% } %>

            <h3 style="margin:10px 0 6px;"><%= pg.title %></h3>
            <div class="small"><%= pg.city %> <%= pg.area ? ("- " + pg.area) : "" %></div>
            <div style="margin:8px 0;"><b>₹<%= pg.price %></b> / month</div>

            <div class="row">
              <a class="btn secondary" href="/pg/<%= pg.id %>">View</a>
              <% if (currentUser) { %>
                <a class="btn" href="/book/<%= pg.id %>">Book</a>
              <% } else { %>
                <a class="btn" href="/login">Login to Book</a>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>