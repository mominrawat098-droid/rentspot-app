<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>RentSpot</title>
  <link rel="stylesheet" href="/public/style.css" />
</head>
<body>

  <!-- IMPORTANT: tumhare project me file hai views/partials/nav.ejs -->
  <%- include("partials/nav") %>

  <div class="container" style="padding:18px 0 28px;">
    <h2>Available PGs</h2>

    <% if (!pgs || pgs.length === 0) { %>
      <p>No PG added yet.</p>
    <% } else { %>
      <div class="grid">
        <% pgs.forEach(pg => { %>
          <div class="card">
            <% if (pg.image) { %>
              <img src="<%= pg.image %>" alt="pg" style="width:100%; height:160px; object-fit:cover;">
            <% } %>

            <div class="card-body">
              <h3><%= pg.title %></h3>
              <p><%= pg.city || "" %></p>
              <p><b>₹<%= pg.price || 0 %></b></p>

              <div style="display:flex; gap:10px; flex-wrap:wrap;">
                <a class="btn" href="/pg/<%= pg.id %>">View</a>

                <% if (pg.whatsapp) { %>
                  <a class="btn" target="_blank" href="https://wa.me/<%= pg.whatsapp.replace(/\D/g,'') %>">WhatsApp</a>
                <% } %>

                <% if (pg.location_url) { %>
                  <a class="btn" target="_blank" href="<%= pg.location_url %>">Location</a>
                <% } %>

                <% if (user) { %>
                  <form action="/book/<%= pg.id %>" method="POST" style="margin:0;">
                    <button class="btn" type="submit">Book</button>
                  </form>
                <% } else { %>
                  <a class="btn" href="/login">Login to Book</a>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

</body>
</html>