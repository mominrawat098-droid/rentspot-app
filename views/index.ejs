<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="stylesheet" href="/style.css">
  <title>Rent Spot</title>
</head>
<body>

<div class="nav">
  <div class="container nav-inner">
    <div class="brand">
      <div class="logo">🏡</div>
      <a href="/">Rent Spot</a>
    </div>

    <div class="nav-links">
      <% if(user){ %>
        <a class="btn" href="/my-bookings">My Bookings</a>
        <a class="btn" href="/messages">Messages <% if(unread>0){ %>(<%= unread %>)<% } %></a>
        <% if(user.role==="admin"){ %>
          <a class="btn" href="/admin">Dashboard</a>
        <% } %>
        <a class="btn" href="/logout">Logout</a>
      <% } else { %>
        <a class="btn" href="/login">Login</a>
        <a class="btn btn-primary" href="/register">Register</a>
      <% } %>
    </div>
  </div>
</div>

<div class="container">

  <!-- HERO PANEL -->
  <div class="hero">
    <div>
      <h1>Find Your Perfect PG</h1>
      <p>Affordable rooms, verified listings and instant booking.</p>

      <% if(!user){ %>
        <a href="/register" class="hero-btn">SIGN UP</a>
      <% } else { %>
        <a href="/my-bookings" class="hero-btn">MY BOOKINGS</a>
      <% } %>
    </div>

    <div>
      <div style="background:#fff; height:160px; border-radius:20px;"></div>
    </div>
  </div>

  <h2>Available PG</h2>

  <div class="cards">
    <% properties.forEach(p => { %>
      <div class="card">
        <% if(p.image){ %>
          <img src="/uploads/<%= p.image %>">
        <% } else { %>
          <img src="https://via.placeholder.com/400x200?text=No+Image">
        <% } %>

        <div class="card-body">
          <h3><%= p.title %></h3>
          <div class="muted"><%= p.location %></div>
          <div>₹ <b><%= p.price %></b>/month</div>
          <div class="muted">Rating: <%= p.avg_rating || 0 %> ★ (<%= p.rating_count || 0 %>)</div>

          <div style="margin-top:10px;">
            <a class="btn" href="/property/<%= p.id %>">View</a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

</div>

</body>
</html>