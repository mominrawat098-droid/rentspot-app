<!DOCTYPE html>
<html>
<head>
  <title>Admin - Broadcast</title>
  <link rel="stylesheet" href="/public/style.css">
  <meta name="viewport" content="width=device-width,initial-scale=1">
</head>
<body>
  <%- include("partials/nav") %>
  <div class="container">
    <div class="card">
      <h2>Broadcast Message</h2>
      <% if (error) { %><div class="error"><%= error %></div><% } %>
      <% if (sent) { %><div class="success"><%= sent %></div><% } %>

      <form method="post" action="/admin/message">
        <label class="label">Title</label>
        <input class="input" name="title" required>

        <label class="label">Message</label>
        <textarea class="input" name="message" rows="4" required></textarea>

        <div style="margin-top:12px;">
          <button class="btn" type="submit">Send</button>
        </div>

        <p class="small" style="margin-top:10px;">This sends in-app notifications. SMTP set ho to email bhi jayega.</p>
      </form>
    </div>
  </div>
</body>
</html>