<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="stylesheet" href="/style.css">
  <title>Login</title>
</head>
<body>
  <%- include("partials_nav") %>

  <div class="container" style="padding:18px 0;">
    <h2>Login</h2>

    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>

    <form class="card" action="/login" method="post">
      <label>Email</label>
      <input name="email" type="email" required>

      <label>Password</label>
      <input name="password" type="password" required>

      <button class="btn" type="submit" style="margin-top:12px;">Login</button>
      <div class="muted" style="margin-top:10px;">No account? <a href="/register">Register</a></div>
    </form>
  </div>
</body>
</html>