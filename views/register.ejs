<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="stylesheet" href="/style.css">
  <title>Register</title>
</head>
<body>
  <%- include("partials_nav") %>

  <div class="container" style="padding:18px 0;">
    <h2>Register</h2>

    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>

    <form class="card" action="/register" method="post">
      <label>Name</label>
      <input name="name" required>

      <label>Email</label>
      <input name="email" type="email" required>

      <label>Password</label>
      <input name="password" type="password" required>

      <button class="btn" type="submit" style="margin-top:12px;">Create Account</button>
      <div class="muted" style="margin-top:10px;">Already have account? <a href="/login">Login</a></div>
    </form>

    <div class="muted" style="margin-top:10px;">
      Note: First registered user becomes <b>Admin</b>.
    </div>
  </div>
</body>
</html>