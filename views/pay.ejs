<!DOCTYPE html>
<html>
<head>
  <title>Payment</title>
  <link rel="stylesheet" href="/public/style.css">
  <meta name="viewport" content="width=device-width,initial-scale=1">
</head>
<body>
  <%- include("partials/nav") %>
  <div class="container">
    <div class="card">
      <h2>Payment</h2>
      <p><b>Booking:</b> #<%= booking.id %> | <b>PG:</b> <%= booking.title %></p>
      <p><b>Amount:</b> ₹<%= booking.price %></p>

      <div class="card">
        <h3>UPI Details</h3>
        <p><b>Payee:</b> <%= ps.payee_name || "-" %></p>
        <p><b>UPI ID:</b> <%= ps.upi_id || "-" %></p>
        <p class="small"><%= ps.note || "" %></p>

        <% if (ps.upi_id) { %>
          <a class="btn" target="_blank"
             href="upi://pay?pa=<%= encodeURIComponent(ps.upi_id) %>&pn=<%= encodeURIComponent(ps.payee_name||'RentSpot') %>&am=<%= booking.price %>&cu=INR&tn=<%= encodeURIComponent('Booking '+booking.id) %>">
            Pay with UPI App
          </a>
        <% } else { %>
          <div class="error">Admin has not set UPI details yet.</div>
        <% } %>
      </div>

      <p class="small">Demo payment flow. Real gateway (Razorpay) can be added later.</p>
    </div>
  </div>
</body>
</html>