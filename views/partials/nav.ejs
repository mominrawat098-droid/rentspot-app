<div class="nav">
  <div class="nav-inner container" style="padding: 12px 18px;">
    <div style="font-weight:800;">
      <a href="/">RentSpot</a>
    </div>

    <div class="nav-links">
      <a class="btn secondary" href="/">Home</a>

      <% if (currentUser) { %>
        <a class="btn secondary" href="/my-bookings">My Bookings</a>
        <a class="btn secondary" href="/notifications">Notifications <span class="badge"><%= userUnreadCount %></span></a>

        <% if (currentUser.role === "admin") { %>
          <a class="btn" href="/admin">Admin</a>
          <a class="btn secondary" href="/admin/notifications">Admin Alerts <span class="badge"><%= adminUnreadCount %></span></a>
        <% } %>

        <a class="btn secondary" href="/logout">Logout</a>
      <% } else { %>
        <a class="btn secondary" href="/login">Login</a>
        <a class="btn" href="/register">Register</a>
      <% } %>
    </div>
  </div>
</div>