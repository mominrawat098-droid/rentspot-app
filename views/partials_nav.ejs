<div class="nav">
  <div class="container nav-inner">
    <div class="brand">
      <a href="/" style="font-weight:700; font-size:18px;">RentSpot</a>
    </div>

    <div class="nav-links">
      <a class="btn" href="/">Home</a>

      <% if (me) { %>
        <a class="btn" href="/notifications">
          🔔 Notifications
          <% if (unreadCount && unreadCount > 0) { %>
            <span class="badge"><%= unreadCount %></span>
          <% } %>
        </a>

        <% if (me.role === "admin") { %>
          <a class="btn" href="/admin/pg/add">Add PG</a>
          <a class="btn" href="/admin/bookings">Bookings</a>
          <a class="btn" href="/admin/notifications">
            Admin 🔔
            <% if (adminUnreadCount && adminUnreadCount > 0) { %>
              <span class="badge"><%= adminUnreadCount %></span>
            <% } %>
          </a>
        <% } %>

        <a class="btn" href="/logout">Logout</a>
      <% } else { %>
        <a class="btn" href="/login">Login</a>
        <a class="btn" href="/register">Register</a>
      <% } %>
    </div>
  </div>
</div>