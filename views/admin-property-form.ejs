<!DOCTYPE html>
<html>
<head>
  <title>Add PG</title>
  <link rel="stylesheet" href="/public/style.css">
  <meta name="viewport" content="width=device-width,initial-scale=1">
</head>
<body>
  <%- include("partials/nav") %>
  <div class="container">
    <div class="card">
      <h2>Add PG</h2>
      <% if (error) { %><div class="error"><%= error %></div><% } %>

      <form method="post" action="/admin/properties/add" enctype="multipart/form-data">
        <label class="label">Title *</label>
        <input class="input" name="title" required>

        <div class="row">
          <div>
            <label class="label">City</label>
            <input class="input" name="city">
          </div>
          <div>
            <label class="label">Area</label>
            <input class="input" name="area">
          </div>
        </div>

        <label class="label">Address</label>
        <input class="input" name="address">

        <label class="label">Price (₹) *</label>
        <input class="input" name="price" type="number" required>

        <label class="label">Description</label>
        <textarea class="input" name="description" rows="4"></textarea>

        <label class="label">Facilities</label>
        <textarea class="input" name="facilities" rows="3"></textarea>

        <div class="row">
          <div>
            <label class="label">Owner Name</label>
            <input class="input" name="owner_name">
          </div>
          <div>
            <label class="label">Owner Phone</label>
            <input class="input" name="owner_phone">
          </div>
        </div>

        <div class="row">
          <div>
            <label class="label">WhatsApp Number (with country code, e.g. 91xxxxxxxxxx)</label>
            <input class="input" name="whatsapp_number">
          </div>
          <div>
            <label class="label">Google Maps Location URL</label>
            <input class="input" name="location_url">
          </div>
        </div>

        <label class="label">Images (max 6)</label>
        <input class="input" name="images" type="file" multiple accept="image/*">

        <div style="margin-top:12px;">
          <button class="btn" type="submit">Add PG</button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>