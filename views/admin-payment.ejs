<!DOCTYPE html>
<html>
<head>
  <title>Admin - Payment Settings</title>
  <link rel="stylesheet" href="/public/style.css">
  <meta name="viewport" content="width=device-width,initial-scale=1">
</head>
<body>
  <%- include("partials/nav") %>
  <div class="container">
    <div class="card">
      <h2>Payment Settings (UPI)</h2>
      <% if (saved) { %><div class="success">Saved</div><% } %>

      <form method="post" action="/admin/payment">
        <label class="label">Payee Name</label>
        <input class="input" name="payee_name" value="<%= ps.payee_name || '' %>">

        <label class="label">UPI ID</label>
        <input class="input" name="upi_id" value="<%= ps.upi_id || '' %>">

        <label class="label">Note</label>
        <textarea class="input" name="note" rows="3"><%= ps.note || '' %></textarea>

        <div style="margin-top:12px;">
          <button class="btn" type="submit">Save</button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>