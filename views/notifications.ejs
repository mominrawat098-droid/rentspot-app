<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="stylesheet" href="/style.css">
  <title>Notifications</title>
</head>
<body>
  <%- include("partials_nav") %>

  <div class="container" style="padding:18px 0;">
    <h2>Your Notifications</h2>

    <form action="/notifications/read-all" method="post" style="margin:10px 0;">
      <button class="btn" type="submit">Mark all read</button>
    </form>

    <% if (!items || items.length === 0) { %>
      <p>No notifications.</p>
    <% } else { %>
      <div class="card">
        <% items.forEach(n => { %>
          <div style="padding:12px; border-bottom:1px solid #eee;">
            <div style="display:flex; justify-content:space-between; gap:10px;">
              <div>
                <b><%= n.title %></b>
                <% if (n.is_read == 0) { %>
                  <span class="pill">NEW</span>
                <% } %>
                <div style="margin-top:6px;"><%= n.message %></div>
                <% if (n.link) { %>
                  <div style="margin-top:6px;"><a href="<%= n.link %>">Open</a></div>
                <% } %>
                <div class="muted" style="margin-top:6px;"><%= n.created_at %></div>
              </div>

              <% if (n.is_read == 0) { %>
                <form action="/notifications/<%= n.id %>/read" method="post">
                  <button class="btn" type="submit">Mark read</button>
                </form>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>