<!DOCTYPE html>
<html>
<head>
  <title>Admin - Bookings</title>
  <link rel="stylesheet" href="/public/style.css">
  <meta name="viewport" content="width=device-width,initial-scale=1">
</head>
<body>
  <%- include("partials/nav") %>
  <div class="container">
    <div class="card">
      <h2>Bookings</h2>

      <table class="table">
        <thead>
          <tr>
            <th>ID</th><th>PG</th><th>User</th><th>Status</th><th>Dates</th><th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach(b => { %>
            <tr>
              <td>#<%= b.id %></td>
              <td><%= b.pg_title %></td>
              <td><%= b.user_name %> (<%= b.user_email %>)</td>
              <td><%= b.status %></td>
              <td class="small"><%= b.checkin %> - <%= b.checkout %></td>
              <td>
                <% if (b.status === "pending") { %>
                  <form method="post" action="/admin/bookings/<%= b.id %>/approve" style="display:inline;">
                    <button class="btn" type="submit">Approve</button>
                  </form>
                  <form method="post" action="/admin/bookings/<%= b.id %>/reject" style="display:inline;">
                    <button class="btn secondary" type="submit">Reject</button>
                  </form>
                <% } else { %>
                  <span class="small">-</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>