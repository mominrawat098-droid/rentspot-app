<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="stylesheet" href="/style.css">
  <title>Add PG</title>
</head>
<body>
  <%- include("partials_nav") %>

  <div class="container" style="padding:18px 0;">
    <h2>Add PG (Admin)</h2>

    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>

    <form class="card" action="/admin/pg/add" method="post" enctype="multipart/form-data">
      <label>Title</label>
      <input name="title" required>

      <label>City</label>
      <input name="city" required>

      <label>Address</label>
      <input name="address">

      <label>Price (₹)</label>
      <input name="price" type="number" required>

      <label>Phone</label>
      <input name="phone">

      <label>Description</label>
      <textarea name="description" rows="4"></textarea>

      <label>Photos (select multiple)</label>
      <input name="photos" type="file" accept="image/*" multiple>

      <button class="btn" type="submit" style="margin-top:12px;">Add PG</button>
      <div class="muted" style="margin-top:8px;">Max 10 photos, 5MB each.</div>
    </form>
  </div>
</body>
</html>