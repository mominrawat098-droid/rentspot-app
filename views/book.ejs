<!DOCTYPE html>
<html>
<head>
  <title>Book</title>
  <link rel="stylesheet" href="/public/style.css">
  <meta name="viewport" content="width=device-width,initial-scale=1">
</head>
<body>
  <%- include("partials/nav") %>
  <div class="container">
    <div class="card">
      <h2>Book: <%= pg.title %></h2>
      <% if (error) { %><div class="error"><%= error %></div><% } %>

      <form method="post" action="/book/<%= pg.id %>">
        <div class="row">
          <div>
            <label class="label">Check-in</label>
            <input class="input" name="checkin" type="date">
          </div>
          <div>
            <label class="label">Check-out</label>
            <input class="input" name="checkout" type="date">
          </div>
        </div>

        <div style="margin-top:12px;">
          <button class="btn" type="submit">Confirm Booking</button>
        </div>
        <p class="small" style="margin-top:10px;">Booking will be approved by Admin.</p>
      </form>
    </div>
  </div>
</body>
</html>