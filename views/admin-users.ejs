<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="stylesheet" href="/style.css">
  <title>Admin - Users</title>
</head>
<body>

<div class="nav">
  <div class="container nav-inner">
    <div class="brand"><div class="logo">🏡</div><a href="/admin">Admin</a></div>
    <div class="nav-links">
      <a class="btn" href="/admin">Dashboard</a>
      <a class="btn btn-primary" href="/admin/users">Users</a>
      <a class="btn" href="/admin/properties/add">Add PG</a>
      <a class="btn" href="/admin/message">Send Message</a>
      <a class="btn" href="/admin/payment">Payment</a>
      <a class="btn" href="/">Home</a>
      <a class="btn" href="/logout">Logout</a>
    </div>
  </div>
</div>

<div class="container" style="padding:18px 0 28px;">
  <h2>Users</h2>

  <table class="table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Email</th>
        <th>Status</th>
        <th>Action</th>
      </tr>
    </thead>

    <tbody>
      <% if(!users || users.length===0){ %>
        <tr><td colspan="5" class="muted">No users</td></tr>
      <% } %>

      <% (users || []).forEach(u => { %>
        <tr>
          <td><%= u.id %></td>
          <td><%= u.name %></td>
          <td><%= u.email %></td>
          <td><b><%= u.status %></b></td>
          <td style="display:flex; gap:8px; flex-wrap:wrap;">
            <% if(u.status !== "Approved"){ %>
              <form method="POST" action="/admin/users/approve/<%= u.id %>">
                <button class="btn btn-primary" type="submit">Approve</button>
              </form>
            <% } %>

            <% if(u.status !== "Rejected"){ %>
              <form method="POST" action="/admin/users/reject/<%= u.id %>">
                <button class="btn" type="submit">Reject</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

</body>
</html>