<!DOCTYPE html>
<html>
<head>
  <title>Admin - Users</title>
  <link rel="stylesheet" href="/public/style.css">
  <meta name="viewport" content="width=device-width,initial-scale=1">
</head>
<body>
  <%- include("partials/nav") %>
  <div class="container">
    <div class="card">
      <h2>Users</h2>

      <table class="table">
        <thead>
          <tr>
            <th>ID</th><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
            <tr>
              <td>#<%= u.id %></td>
              <td><%= u.name %></td>
              <td><%= u.email %></td>
              <td><%= u.role %></td>
              <td><%= u.status %></td>
              <td>
                <% if (u.role === "user" && u.status === "pending") { %>
                  <form method="post" action="/admin/users/<%= u.id %>/approve" style="display:inline;">
                    <button class="btn" type="submit">Approve</button>
                  </form>
                <% } else { %>
                  <span class="small">-</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>